PORT=8788

# Local validation: demo | mock-x402
# Production: okx-x402
PAYMENT_MODE=mock-x402

PUBLIC_BASE_URL=https://your-domain.example

# x402 payment terms. Per-service amounts come from the service catalog.
X402_NETWORK=eip155:196
X402_PAY_TO=0xYourReceivingAddress
X402_ASSET=0x779ded0c9e1022225f8e0630b35a9b54be713736
X402_TOKEN_NAME=USDt0
X402_TOKEN_SYMBOL=USDT0
X402_TOKEN_DECIMALS=6
X402_TOKEN_VERSION=1
MCP_FEE_USDT=0.03

# Upstream data and resilience
UPSTREAM_TIMEOUT_MS=4000
PROVIDER_BUDGET_MS=4500
MARKET_CACHE_MS=30000
SECURITY_CACHE_MS=300000
GECKOTERMINAL_API_BASE=https://api.geckoterminal.com/api/v2
GOPLUS_ACCESS_TOKEN=

# Required only for PAYMENT_MODE=okx-x402
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_FACILITATOR_BASE_URL=
X402_SYNC_SETTLE=0
